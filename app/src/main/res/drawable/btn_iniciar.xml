<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Cuando se presiona -->
    <item android:state_pressed="true">
        <shape>
            <gradient
                android:startColor="#2BB7DA"
                android:endColor="#1A8CA8"
                android:angle="270"/>
            <corners android:radius="12dp"/>
        </shape>
    </item>

    <!-- Estado normal -->
    <item>
        <shape>
            <gradient
                android:startColor="#6EE7FF"
                android:endColor="#2BB7DA"
                android:angle="270"/>
            <corners android:radius="12dp"/>
        </shape>
    </item>

</selector>