<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A2A4A">

    <!-- BARRA SUPERIOR -->
    <LinearLayout
        android:id="@+id/barraTop"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="10dp"
        android:background="#0E3C6E"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:src="@drawable/ic_regresar"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="PanchitoMap"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:paddingStart="10dp"/>

        <Button
            android:id="@+id/btnGuardarMapa"
            android:layout_width="90dp"
            android:layout_height="35dp"
            android:background="@drawable/btn_iniciar"
            android:text="Guardar"/>
    </LinearLayout>

    <!-- MAPA -->
    <FrameLayout
        android:id="@+id/mapContainer"
        android:layout_width="match_parent"
        android:layout_height="223dp"
        android:background="#E5E5E5"
        app:layout_constraintTop_toBottomOf="@id/barraTop"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.example.app_panchito_explorer.MapaPreviewView
            android:id="@+id/mapaPreview"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>
    </FrameLayout>

    <!-- PANEL DATOS -->
    <LinearLayout
        android:id="@+id/panelDatos"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#0E3C6E"
        android:padding="10dp"
        app:layout_constraintTop_toBottomOf="@id/mapContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:text="Tiempo\n00:00"
                android:background="@drawable/bg_card"
                android:textColor="#FFFFFF"
                android:gravity="center"/>

            <TextView
                android:id="@+id/tvDistancia"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:text="Distancia\n0.0 M"
                android:background="@drawable/bg_card"
                android:textColor="#FFFFFF"
                android:gravity="center"
                android:layout_marginStart="5dp"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:text="Batería\n--"
                android:background="@drawable/bg_card"
                android:textColor="#FFFFFF"
                android:gravity="center"
                android:layout_marginStart="5dp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="5dp">

            <TextView
                android:id="@+id/tvPequenos"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:text="Pequeños\n0"
                android:background="@drawable/bg_card"
                android:textColor="#FFFFFF"
                android:gravity="center"/>

            <TextView
                android:id="@+id/tvGrandes"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:text="Grandes\n0"
                android:background="@drawable/bg_card"
                android:textColor="#FFFFFF"
                android:gravity="center"
                android:layout_marginStart="5dp"/>
        </LinearLayout>
    </LinearLayout>

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_half"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.5" />

    <!-- CONTROLES -->
    <LinearLayout
        android:id="@+id/zonaControl"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="horizontal"
        android:padding="10dp"
        app:layout_constraintTop_toBottomOf="@id/panelDatos"
        app:layout_constraintBottom_toTopOf="@id/botonesBottom"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <RelativeLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="2"
            android:background="@drawable/bg_joystick">

            <ImageButton android:id="@+id/btnUp" android:layout_width="60dp" android:layout_height="60dp" android:layout_centerHorizontal="true" android:layout_marginTop="10dp" android:background="@drawable/bg_card" android:src="@drawable/ic_arriba" app:tint="#00E5FF" />
            <ImageButton android:id="@+id/btnLeft" android:layout_width="60dp" android:layout_height="60dp" android:layout_centerVertical="true" android:layout_marginStart="10dp" android:background="@drawable/bg_card" android:src="@drawable/ic_izquierda" app:tint="#00E5FF" />
            <ImageButton android:id="@+id/btnStop" android:layout_width="60dp" android:layout_height="60dp" android:layout_centerInParent="true" android:background="@drawable/bg_card" android:src="@drawable/ic_centro" app:tint="#00E5FF" />
            <ImageButton android:id="@+id/btnRight" android:layout_width="60dp" android:layout_height="60dp" android:layout_alignParentEnd="true" android:layout_centerVertical="true" android:layout_marginEnd="10dp" android:background="@drawable/bg_card" android:src="@drawable/ic_derecha" app:tint="#00E5FF" />
            <ImageButton android:id="@+id/btnDown" android:layout_width="60dp" android:layout_height="60dp" android:layout_alignParentBottom="true" android:layout_centerHorizontal="true" android:layout_marginBottom="10dp" android:background="@drawable/bg_card" android:src="@drawable/ic_abajo" app:tint="#00E5FF" />
        </RelativeLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="#0E3C6E" android:gravity="center" android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Servo" android:textColor="#FFFFFF" android:layout_marginBottom="5dp"/>
            <ImageButton android:id="@+id/btnServoLeft" android:layout_width="54dp" android:layout_height="44dp" android:background="@drawable/bg_card" android:src="@drawable/ic_izquierda" android:layout_marginBottom="4dp" app:tint="#00E5FF" />
            <ImageButton android:id="@+id/btnServoCenter" android:layout_width="54dp" android:layout_height="44dp" android:background="@drawable/bg_card" android:src="@drawable/ic_centro" android:layout_marginBottom="4dp" app:tint="#00E5FF" />
            <ImageButton android:id="@+id/btnServoRight" android:layout_width="54dp" android:layout_height="44dp" android:background="@drawable/bg_card" android:src="@drawable/ic_derecha" app:tint="#00E5FF" />
        </LinearLayout>

        <LinearLayout android:id="@+id/panelVelocidad" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="#0E3C6E" android:gravity="center" android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Velocidad" android:textColor="#FFFFFF" android:layout_marginBottom="5dp"/>
            <TextView android:id="@+id/tvVelocidadNumero" android:layout_width="70dp" android:layout_height="70dp" android:background="@drawable/bg_card" android:gravity="center" android:text="1" android:textColor="#00E5FF" android:textSize="32sp" android:textStyle="bold"/>
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/botonesBottom"
        android:layout_width="0dp"
        android:layout_height="85dp"
        android:orientation="horizontal"
        android:padding="6dp"
        android:background="#0E3C6E"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout android:id="@+id/btnIniciarSesion" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="4dp" android:orientation="vertical" android:gravity="center" android:background="@drawable/bg_card" android:padding="6dp">
            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_coche" app:tint="#00E5FF"/><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Iniciar" android:textSize="12sp" android:textColor="#FFFFFF" android:layout_marginTop="4dp"/>
        </LinearLayout>
        <LinearLayout android:id="@+id/btnMedirModo" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="4dp" android:orientation="vertical" android:gravity="center" android:background="@drawable/bg_card" android:padding="6dp">
            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_medir" app:tint="#00E5FF"/><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Medir" android:textSize="12sp" android:textColor="#FFFFFF" android:layout_marginTop="4dp"/>
        </LinearLayout>
        <LinearLayout android:id="@+id/btnAutoModo" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="4dp" android:orientation="vertical" android:gravity="center" android:background="@drawable/bg_card" android:padding="6dp">
            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_robot" app:tint="#00E5FF"/><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Auto" android:textSize="12sp" android:textColor="#FFFFFF" android:layout_marginTop="4dp"/>
        </LinearLayout>
        <LinearLayout android:id="@+id/btnUbicarModo" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="4dp" android:orientation="vertical" android:gravity="center" android:background="@drawable/bg_card" android:padding="6dp">
            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_map" app:tint="#00E5FF"/><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Ubicar" android:textSize="12sp" android:textColor="#FFFFFF" android:layout_marginTop="4dp"/>
        </LinearLayout>
        <LinearLayout android:id="@+id/btnVolverOrigen" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="4dp" android:orientation="vertical" android:gravity="center" android:background="@drawable/bg_card" android:padding="6dp">
            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_regresar" app:tint="#00E5FF"/><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Origen" android:textSize="12sp" android:textColor="#FFFFFF" android:layout_marginTop="4dp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- ALERTA DE DESCONEXIÓN (CUBRE MITAD SUPERIOR) -->
    <LinearLayout
        android:id="@+id/layoutErrorConexion"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#D9B71C1C"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="vertical"
        android:elevation="100dp"
        android:padding="20dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/guideline_half"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@android:drawable/ic_dialog_alert"
            app:tint="#FFFFFF" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            android:text="¡CONEXIÓN PERDIDA!"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="El robot se ha desconectado.\nEl mapeo se detuvo por seguridad."
            android:textColor="#FFFFFF"
            android:textSize="16sp" />

        <Button
            android:id="@+id/btnEntendidoError"
            android:layout_width="200dp"
            android:layout_height="55dp"
            android:layout_marginTop="25dp"
            android:text="RECONECTAR"
            android:backgroundTint="#FFFFFF"
            android:textColor="#B71C1C"
            android:textStyle="bold" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
