<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A2A4A">

    <!-- BARRA SUPERIOR -->

    <LinearLayout
        android:id="@+id/barraTop"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="10dp"
        android:background="#0E3C6E"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:src="@drawable/ic_regresar"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="PanchitoMap"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:paddingStart="10dp"/>

        <Button
            android:background="@drawable/btn_iniciar"
            android:id="@+id/btnGuardarMapa"
            android:layout_width="90dp"
            android:layout_height="35dp"
            android:text="Guardar"/>
    </LinearLayout>


    <!-- MAPA -->

    <FrameLayout
        android:id="@+id/mapContainer"
        android:layout_width="410dp"
        android:layout_height="223dp"
        android:background="#E5E5E5"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/barraTop">

        <!-- OESTE -->
        <TextView
            android:id="@+id/tvOeste"
            android:layout_width="70dp"
            android:layout_height="50dp"
            android:layout_gravity="top|start"
            android:background="@drawable/bg_card"
            android:padding="5dp"
            android:text="Oeste\n0 M"
            android:textColor="#FFFFFF" />

        <!-- NORTE -->
        <TextView
            android:id="@+id/tvNorte"
            android:layout_width="70dp"
            android:layout_height="50dp"
            android:layout_gravity="top|end"
            android:background="@drawable/bg_card"
            android:padding="5dp"
            android:text="Norte\n0 M"
            android:textColor="#FFFFFF" />

        <!-- SUR -->
        <TextView
            android:id="@+id/tvSur"
            android:layout_width="70dp"
            android:layout_height="50dp"
            android:layout_gravity="bottom|start"
            android:background="@drawable/bg_card"
            android:padding="5dp"
            android:text="Sur\n0 M"
            android:textColor="#FFFFFF" />

        <!-- ESTE -->
        <TextView
            android:id="@+id/tvEste"
            android:layout_width="70dp"
            android:layout_height="50dp"
            android:layout_gravity="bottom|end"
            android:background="@drawable/bg_card"
            android:padding="5dp"
            android:text="Este\n0 M"
            android:textColor="#FFFFFF" />

    </FrameLayout>


    <!-- PANEL DATOS -->

    <LinearLayout
        android:id="@+id/panelDatos"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#0E3C6E"
        android:padding="10dp"
        app:layout_constraintTop_toBottomOf="@id/mapContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- FILA 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:text="Tiempo\n00:07"
                android:background="@drawable/bg_card"
                android:textColor="#FFFFFF"
                android:gravity="center"/>

            <TextView
                android:id="@+id/tvDistancia"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:text="Distancia\n0 M"
                android:background="@drawable/bg_card"
                android:textColor="#FFFFFF"
                android:gravity="center"
                android:layout_marginStart="5dp"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:text="Batería\n83%"
                android:background="@drawable/bg_card"
                android:textColor="#FFFFFF"
                android:gravity="center"
                android:layout_marginStart="5dp"/>

        </LinearLayout>

        <!-- FILA 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="5dp">

            <TextView
                android:id="@+id/tvPequenos"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:text="Pequeños\n12"
                android:background="@drawable/bg_card"
                android:textColor="#FFFFFF"
                android:gravity="center"/>

            <TextView
                android:id="@+id/tvGrandes"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:text="Grandes\n13"
                android:background="@drawable/bg_card"
                android:textColor="#FFFFFF"
                android:gravity="center"
                android:layout_marginStart="5dp"/>

        </LinearLayout>

    </LinearLayout>


    <!-- CONTROLES -->

    <LinearLayout
        android:id="@+id/zonaControl"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="horizontal"
        android:padding="10dp"
        app:layout_constraintTop_toBottomOf="@id/panelDatos"
        app:layout_constraintBottom_toTopOf="@id/botonesBottom"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- JOYSTICK -->


        <!-- VELOCIDAD -->

        <RelativeLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="2"
            android:background="@drawable/bg_joystick">

            <ImageButton
                android:layout_margin="4dp"
                android:id="@+id/btnUp"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_card"
                android:padding="10dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_arriba"
                app:tint="#00E5FF" />

            <ImageButton
                android:id="@+id/btnLeft"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_centerVertical="true"
                android:layout_marginStart="10dp"
                android:background="@drawable/bg_card"
                android:padding="10dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_izquierda"
                app:tint="#00E5FF" />

            <ImageButton
                android:layout_margin="4dp"
                android:id="@+id/btnStop"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_centerInParent="true"
                android:background="@drawable/bg_card"
                android:padding="10dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_centro"
                app:tint="#00E5FF" />

            <ImageButton
                android:id="@+id/btnRight"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:layout_marginEnd="10dp"
                android:background="@drawable/bg_card"
                android:padding="10dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_derecha"
                app:tint="#00E5FF" />

            <ImageButton
                android:layout_margin="4dp"
                android:id="@+id/btnDown"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_alignParentBottom="true"
                android:layout_centerHorizontal="true"
                android:layout_marginBottom="10dp"
                android:background="@drawable/bg_card"
                android:padding="10dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_abajo"
                app:tint="#00E5FF" />

        </RelativeLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="#0E3C6E"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Velocidad"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="10dp"/>

            <ImageView
                android:id="@+id/imgVelocidad"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:src="@drawable/ic_coche"
                android:scaleType="centerInside"/>

        </LinearLayout>

    </LinearLayout>


    <!-- BOTONES INFERIORES -->

    <LinearLayout
        android:id="@+id/botonesBottom"
        android:layout_width="0dp"
        android:layout_height="85dp"
        android:orientation="horizontal"
        android:padding="6dp"
        android:background="#0E3C6E"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/btnIniciarSesion"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_margin="4dp"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_card"
            android:padding="6dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_coche"
                app:tint="#00E5FF"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Iniciar"
                android:textSize="12sp"
                android:textColor="#FFFFFF"
                android:layout_marginTop="4dp"/>

        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_margin="4dp"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_card"
            android:padding="6dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_stop"
                app:tint="#00E5FF"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Stop"
                android:textSize="12sp"
                android:textColor="#FFFFFF"
                android:layout_marginTop="4dp"/>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnMedirModo"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_margin="4dp"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_card"
            android:padding="6dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_medir"
                app:tint="#00E5FF"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Medir"
                android:textSize="12sp"
                android:textColor="#FFFFFF"
                android:layout_marginTop="4dp"/>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnAutoModo"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_margin="4dp"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_card"
            android:padding="6dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_robot"
                app:tint="#00E5FF"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Auto"
                android:textSize="12sp"
                android:textColor="#FFFFFF"
                android:layout_marginTop="4dp"/>

        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
