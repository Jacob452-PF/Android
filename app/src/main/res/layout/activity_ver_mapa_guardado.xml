<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A2A4A">

    <LinearLayout
        android:id="@+id/header"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="10dp"
        android:background="#0E3C6E"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:src="@drawable/ic_regresar"/>

        <TextView
            android:id="@+id/tituloMapa"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Mapa guardado"
            android:textColor="#FFF"
            android:textSize="18sp"
            android:gravity="center"/>

    </LinearLayout>

    <FrameLayout
        android:id="@+id/mapa"
        android:layout_width="0dp"
        android:layout_height="250dp"
        android:background="#E5E5E5"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.example.app_panchito_explorer.MapaPreviewView
            android:id="@+id/mapaPreview"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>

        <TextView
            android:id="@+id/tvOesteGuardado"
            android:layout_width="70dp"
            android:layout_height="50dp"
            android:visibility="gone"
            android:text="Oeste\n0 M"
            android:background="@drawable/bg_card"
            android:textColor="#FFF"
            android:gravity="center"
            android:layout_gravity="top|start"/>

        <TextView
            android:id="@+id/tvNorteGuardado"
            android:layout_width="70dp"
            android:layout_height="50dp"
            android:visibility="gone"
            android:text="Norte\n0 M"
            android:background="@drawable/bg_card"
            android:textColor="#FFF"
            android:gravity="center"
            android:layout_gravity="top|end"/>

        <TextView
            android:id="@+id/tvSurGuardado"
            android:layout_width="70dp"
            android:layout_height="50dp"
            android:visibility="gone"
            android:text="Sur\n0 M"
            android:background="@drawable/bg_card"
            android:textColor="#FFF"
            android:gravity="center"
            android:layout_gravity="bottom|start"/>

        <TextView
            android:id="@+id/tvEsteGuardado"
            android:layout_width="70dp"
            android:layout_height="50dp"
            android:visibility="gone"
            android:text="Este\n0 M"
            android:background="@drawable/bg_card"
            android:textColor="#FFF"
            android:gravity="center"
            android:layout_gravity="bottom|end"/>

        <Button
            android:id="@+id/btnSalirPantallaCompleta"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:layout_gravity="top|end"
            android:layout_margin="12dp"
            android:background="@drawable/btn_iniciar"
            android:text="Salir"
            android:textColor="#FFF"
            android:visibility="gone"/>

    </FrameLayout>

    <LinearLayout
        android:id="@+id/acciones"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:padding="10dp"
        app:layout_constraintTop_toBottomOf="@id/mapa"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btnExportar"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Exportar"
            android:background="@drawable/btn_iniciar"
            android:textColor="#FFF"/>

        <Button
            android:id="@+id/btnEliminar"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Eliminar"
            android:layout_marginStart="10dp"
            android:background="@drawable/btn_iniciar"
            android:textColor="#FFF"/>

        <Button
            android:id="@+id/btnPantallaCompleta"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Pantalla"
            android:layout_marginStart="10dp"
            android:background="@drawable/btn_iniciar"
            android:textColor="#FFF"/>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/panelDatos"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="@drawable/bg_card"
        app:layout_constraintTop_toBottomOf="@id/acciones"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:text="Datos"
            android:textColor="#FFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_height="wrap_content"
            android:layout_width="wrap_content"/>

        <TextView android:id="@+id/tvTiempo" android:text="Tiempo: 0 s\n" android:textColor="#FFF" android:layout_height="wrap_content" android:layout_width="wrap_content"/>
        <TextView android:id="@+id/tvRuta" android:text="Ruta manual: 0 puntos\n" android:textColor="#FFF" android:layout_height="wrap_content" android:layout_width="wrap_content"/>
        <TextView android:id="@+id/tvDistanciaGuardada" android:text="Distancia: 0 m\n" android:textColor="#FFF" android:layout_height="wrap_content" android:layout_width="wrap_content"/>
        <TextView android:id="@+id/tvPequenosGuardados" android:text="Obstaculos pequenos: 0\n" android:textColor="#FFF" android:layout_height="wrap_content" android:layout_width="wrap_content"/>
        <TextView android:id="@+id/tvGrandesGuardados" android:text="Obstaculos grandes: 0\n" android:textColor="#FFF" android:layout_height="wrap_content" android:layout_width="wrap_content"/>
        <TextView android:id="@+id/tvPuertas" android:text="Puertas posibles: 0\n" android:textColor="#FFF" android:layout_height="wrap_content" android:layout_width="wrap_content"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
