<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_login">

    <!-- Botón volver -->
    <ImageView
        android:id="@+id/btnBack"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:src="@drawable/ic_regresar"
        app:tint="#12E7CC"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <!-- Título -->
    <TextView
        android:id="@+id/textTitulo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="80dp"
        android:layout_marginTop="12dp"
        android:text="Editar dispositivo"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintStart_toEndOf="@id/btnBack"
        app:layout_constraintTop_toTopOf="@id/btnBack" />

    <!-- Imagen carrito -->
    <ImageView
        android:id="@+id/imgCar"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:src="@drawable/ic_coche"
        app:tint="#00E5FF"
        app:layout_constraintTop_toBottomOf="@id/textTitulo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="30dp"/>

    <!-- Nombre editable -->
    <EditText
        android:id="@+id/editNombre"
        android:layout_width="250dp"
        android:layout_height="wrap_content"
        android:text="Panchito_map"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold"
        android:backgroundTint="#00E5FF"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/imgCar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="10dp"/>

    <!-- Descripción editable -->
    <EditText
        android:id="@+id/editDescripcion"
        android:layout_width="280dp"
        android:layout_height="wrap_content"
        android:text="Auto de mapeo remoto"
        android:textColor="#B0D4FF"
        android:textSize="14sp"
        android:backgroundTint="#00E5FF"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/editNombre"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Estado conexión -->
    <Button
        android:id="@+id/btnConexion"
        android:layout_width="0dp"
        android:layout_height="55dp"
        android:text="Conectado ✔"
        android:textColor="#FFFFFF"
        android:backgroundTint="#4FC3F7"
        android:layout_margin="30dp"
        app:layout_constraintTop_toBottomOf="@id/editDescripcion"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Datos NO editables -->
    <LinearLayout
        android:id="@+id/cardDatos"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:background="@drawable/bg_card"
        android:layout_margin="30dp"
        app:layout_constraintTop_toBottomOf="@id/btnConexion"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Dirección MAC"
            android:textColor="#00E5FF"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/textMac"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="00:11:22:33:44"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:layout_marginBottom="15dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Estado"
            android:textColor="#00E5FF"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/textEstado"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Activo"
            android:textColor="#FFFFFF"
            android:textSize="16sp"/>

    </LinearLayout>

    <!-- Guardar -->
    <Button
        android:id="@+id/btnGuardar"
        android:layout_width="0dp"
        android:layout_height="55dp"
        android:text="Guardar cambios"
        android:textColor="#FFFFFF"
        android:backgroundTint="#3F51B5"
        android:layout_marginStart="30dp"
        android:layout_marginEnd="30dp"
        android:layout_marginTop="10dp"
        app:layout_constraintTop_toBottomOf="@id/cardDatos"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>